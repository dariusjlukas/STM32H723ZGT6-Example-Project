 144:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_ll_usb.c **** HAL_StatusTypeDef USB_SetTurnaroundTime(USB_OTG_GlobalTypeDef *USBx,
 145:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_ll_usb.c ****                                         uint32_t hclk, uint8_t speed)
ARM GAS  /tmp/cc2af7qQ.s 			page 4


 146:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_ll_usb.c **** {
 147:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_ll_usb.c ****   uint32_t UsbTrd;
 148:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_ll_usb.c **** 
 149:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_ll_usb.c ****   /* The USBTRD is configured according to the tables below, depending on AHB frequency
 150:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_ll_usb.c ****   used by application. In the low AHB frequency range it is used to stretch enough the USB response
 151:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_ll_usb.c ****   time to IN tokens, the USB turnaround time, so to compensate for the longer AHB read access
 152:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_ll_usb.c ****   latency to the Data FIFO */
 153:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_ll_usb.c ****   if (speed == USBD_FS_SPEED)
 154:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_ll_usb.c ****   {
 155:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_ll_usb.c ****     if ((hclk >= 14200000U) && (hclk < 15000000U))
 156:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_ll_usb.c ****     {
 157:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_ll_usb.c ****       /* hclk Clock Range between 14.2-15 MHz */
 158:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_ll_usb.c ****       UsbTrd = 0xFU;
 159:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_ll_usb.c ****     }
 160:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_ll_usb.c ****     else if ((hclk >= 15000000U) && (hclk < 16000000U))
 161:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_ll_usb.c ****     {
 162:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_ll_usb.c ****       /* hclk Clock Range between 15-16 MHz */
 163:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_ll_usb.c ****       UsbTrd = 0xEU;
 164:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_ll_usb.c ****     }
 165:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_ll_usb.c ****     else if ((hclk >= 16000000U) && (hclk < 17200000U))
 166:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_ll_usb.c ****     {
 167:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_ll_usb.c ****       /* hclk Clock Range between 16-17.2 MHz */
 168:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_ll_usb.c ****       UsbTrd = 0xDU;
 169:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_ll_usb.c ****     }
 170:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_ll_usb.c ****     else if ((hclk >= 17200000U) && (hclk < 18500000U))
 171:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_ll_usb.c ****     {
 172:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_ll_usb.c ****       /* hclk Clock Range between 17.2-18.5 MHz */
 173:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_ll_usb.c ****       UsbTrd = 0xCU;
 174:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_ll_usb.c ****     }
 175:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_ll_usb.c ****     else if ((hclk >= 18500000U) && (hclk < 20000000U))
 176:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_ll_usb.c ****     {
 177:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_ll_usb.c ****       /* hclk Clock Range between 18.5-20 MHz */
 178:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_ll_usb.c ****       UsbTrd = 0xBU;
 179:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_ll_usb.c ****     }
 180:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_ll_usb.c ****     else if ((hclk >= 20000000U) && (hclk < 21800000U))
 181:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_ll_usb.c ****     {
 182:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_ll_usb.c ****       /* hclk Clock Range between 20-21.8 MHz */
 183:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_ll_usb.c ****       UsbTrd = 0xAU;
